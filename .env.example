# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: use a Stripe Price ID instead of dynamic pricing
# STRIPE_PRICE_ID=price_...

# Optional: flat-rate US shipping in cents (e.g. 500 = $5.00). Omit or 0 for free shipping.
# SHIPPING_AMOUNT_CENTS=500

# Public site URL for checkout redirects (required in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Plausible analytics — https://plausible.io (~$9/mo)
# Site Settings → Installation → copy your script URL (pa-XXXXX.js format).
# Script runs in production only.
# NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/pa-XXXXX.js
# Legacy fallback (older accounts only):
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=thebeanbook.org

# Sentry error monitoring — https://sentry.io (free tier)
# Create a Next.js project and paste the DSN. Runs in production only.
# SENTRY_DSN=https://...@....ingest.sentry.io/...

# Google My Maps embed (Map page) — Share → Embed a map → copy iframe src URL
# GOOGLE_MAP_EMBED_URL=https://www.google.com/maps/d/embed?mid=YOUR_MAP_ID
# NEXT_PUBLIC_GOOGLE_MAP_EMBED_URL=...  # legacy alias; prefer GOOGLE_MAP_EMBED_URL

# Database — Supabase Postgres (see Connect → ORM in dashboard)
# DATABASE_URL = transaction pooler (port 6543) for the app
# DIRECT_URL = session pooler (port 5432) for Prisma migrations
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres"

# Admin account (created on first seed)
ADMIN_EMAIL=admin@thebeanbook.org
ADMIN_PASSWORD=change-this-password

# Session cookie signing — use a long random string in production
AUTH_SECRET=generate-a-random-string-at-least-32-characters

# Shippo — https://apps.goshippo.com/api (test token starts with shippo_test_)
SHIPPO_API_TOKEN=shippo_test_...
# Label size: PDF_4x6 (default, thermal 4×6 printers) | PDF (letter 8.5×11) | ZPLII (direct Zebra/Rollo)
# SHIPPO_LABEL_FILE_TYPE=PDF_4x6

# Ship-from address (your fulfillment location)
SHIP_FROM_NAME=The Bean Book
SHIP_FROM_STREET1=123 Example St
# SHIP_FROM_STREET2=Suite 100
SHIP_FROM_CITY=Denver
SHIP_FROM_STATE=CO
SHIP_FROM_ZIP=80202
# SHIP_FROM_COUNTRY=US
# Required for USPS labels (your business contact, not the customer on the order)
SHIP_FROM_PHONE=3035550100
SHIP_FROM_EMAIL=shipping@thebeanbook.org

# Order email alerts — who gets notified when a new order is paid (defaults to ADMIN_EMAIL)
# ORDER_NOTIFY_EMAIL=you@thebeanbook.org

# Email (Resend — https://resend.com) — verify both from addresses in Resend dashboard
RESEND_API_KEY=re_...
EMAIL_SENDER_SHOPS=shops@thebeanbook.org
EMAIL_SENDER_SHOPS_NAME=The Bean Book — Shops
EMAIL_SENDER_CUSTOMERS=admin@thebeanbook.org
EMAIL_SENDER_CUSTOMERS_NAME=The Bean Book

# Bubble mailer defaults (~13 oz book)
PACKAGE_WEIGHT_OZ=13
PACKAGE_LENGTH_IN=10
PACKAGE_WIDTH_IN=8
PACKAGE_HEIGHT_IN=1
